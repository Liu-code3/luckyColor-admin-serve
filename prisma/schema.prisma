generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TenantPackage {
  id           String   @id
  name         String
  code         String   @unique
  status       Boolean  @default(true)
  maxUsers     Int?     @map("max_users")
  maxRoles     Int?     @map("max_roles")
  maxMenus     Int?     @map("max_menus")
  featureFlags Json?    @map("feature_flags")
  remark       String?
  tenants      Tenant[]
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([status])
  @@map("tenant_packages")
}

model Tenant {
  id            String           @id
  code          String           @unique
  name          String
  status        String           @default("ACTIVE")
  expiresAt     DateTime?        @map("expires_at") @db.DateTime(3)
  contactName   String?          @map("contact_name")
  contactPhone  String?          @map("contact_phone")
  contactEmail  String?          @map("contact_email")
  packageId     String?          @map("package_id")
  tenantPackage TenantPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  remark        String?
  auditLogs     TenantAuditLog[]
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([status])
  @@index([packageId])
  @@map("tenants")
}

model TenantAuditLog {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  action           String
  operatorTenantId String?  @map("operator_tenant_id")
  operatorUserId   String?  @map("operator_user_id")
  detail           Json?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([operatorTenantId])
  @@index([operatorUserId])
  @@map("tenant_audit_logs")
}

model DashboardVisit {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  visitorId  String   @map("visitor_id")
  sessionId  String   @map("session_id")
  routePath  String   @map("route_path")
  routeTitle String   @map("route_title")
  routeIcon  String?  @map("route_icon")
  visitedAt  DateTime @default(now()) @map("visited_at") @db.Timestamp(3)

  @@index([tenantId, visitedAt])
  @@index([tenantId, userId, visitedAt])
  @@index([tenantId, sessionId, visitedAt])
  @@index([tenantId, visitorId, visitedAt])
  @@index([tenantId, routePath, visitedAt])
  @@map("dashboard_visits")
}

model SystemLog {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  operatorUserId String   @map("operator_user_id")
  operatorName   String   @map("operator_name")
  module         String
  content        String   @db.Text
  ipAddress      String   @map("ip_address")
  region         String
  browserVersion String   @map("browser_version")
  terminalSystem String   @map("terminal_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([tenantId, createdAt])
  @@index([tenantId, module, createdAt])
  @@index([tenantId, operatorUserId, createdAt])
  @@index([tenantId, operatorName, createdAt])
  @@map("system_logs")
}

model SecurityAuditLog {
  id             String   @id @default(cuid())
  tenantId       String?  @map("tenant_id")
  userId         String?  @map("user_id")
  username       String?
  eventType      String   @map("event_type")
  outcome        String
  reasonCode     Int?     @map("reason_code")
  reasonMessage  String?  @map("reason_message")
  requestMethod  String?  @map("request_method")
  requestPath    String?  @map("request_path")
  ipAddress      String   @map("ip_address")
  browserVersion String   @map("browser_version")
  terminalSystem String   @map("terminal_system")
  detail         Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@index([eventType, createdAt])
  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([username, createdAt])
  @@map("security_audit_logs")
}

model User {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  departmentId Int?        @map("department_id")
  username     String
  password     String
  nickname     String?
  phone        String?
  email        String?
  avatar       String?
  status       Boolean     @default(true)
  lastLoginAt  DateTime?   @map("last_login_at") @db.Timestamp(3)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  roles        UserRole[]
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, username])
  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("users")
}

model Menu {
  id        Int        @id @default(autoincrement())
  parentId  Int?       @map("parent_id")
  title     String
  name      String
  type      Int
  path      String
  menuKey   String     @map("menu_key")
  permissionCode String? @map("permission_code")
  icon      String?
  layout    String?
  isVisible Boolean    @default(true) @map("is_visible")
  status    Boolean    @default(true)
  component String
  redirect  String?
  meta      Json?
  sort      Int        @default(0)
  roles     RoleMenu[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([menuKey])
  @@index([permissionCode])
  @@index([parentId])
  @@index([parentId, sort])
  @@index([sort])
  @@map("menus")
}

model Dictionary {
  id         String   @id
  parentId   String?  @map("parent_id")
  weight     Int
  name       String
  tenantId   String?  @map("tenant_id")
  dictLabel  String   @map("dict_label")
  dictValue  String   @map("dict_value")
  category   String
  sortCode   Int      @map("sort_code")
  status     Boolean  @default(true)
  deleteFlag String   @map("delete_flag")
  createTime String?  @map("create_time")
  createUser String?  @map("create_user")
  updateTime String?  @map("update_time")
  updateUser String?  @map("update_user")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([parentId])
  @@index([status])
  @@index([dictValue])
  @@index([sortCode])
  @@map("dictionaries")
}

model Role {
  id                   String                @id @default(cuid())
  tenantId             String                @map("tenant_id")
  name                 String
  code                 String
  sort                 Int                   @default(0)
  status               Boolean               @default(true)
  dataScope            String                @default("ALL") @map("data_scope")
  remark               String?
  users                UserRole[]
  menus                RoleMenu[]
  permissions          RolePermission[]
  dataScopeDepartments RoleDepartmentScope[]
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([name])
  @@index([sort])
  @@index([tenantId, status, sort])
  @@map("roles")
}

model Department {
  id             Int                   @id @default(autoincrement())
  tenantId       String                @map("tenant_id")
  parentId       Int?                  @map("parent_id")
  name           String
  code           String
  leader         String?
  phone          String?
  email          String?
  sort           Int                   @default(0)
  status         Boolean               @default(true)
  remark         String?
  users          User[]
  dataScopeRoles RoleDepartmentScope[]
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([tenantId, parentId])
  @@index([tenantId, parentId, sort])
  @@index([name])
  @@index([sort])
  @@index([tenantId, status, sort])
  @@map("departments")
}

model UserRole {
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([tenantId])
  @@index([roleId])
  @@map("user_roles")
}

model RoleMenu {
  tenantId   String   @map("tenant_id")
  roleId     String   @map("role_id")
  menuId     Int      @map("menu_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@index([tenantId])
  @@index([menuId])
  @@map("role_menus")
}

model RolePermission {
  tenantId       String   @map("tenant_id")
  roleId         String   @map("role_id")
  permissionCode String   @map("permission_code")
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  role           Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionCode])
  @@index([tenantId])
  @@index([permissionCode])
  @@map("role_permissions")
}

model RoleDepartmentScope {
  tenantId     String     @map("tenant_id")
  roleId       String     @map("role_id")
  departmentId Int        @map("department_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamp(3)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([roleId, departmentId])
  @@index([tenantId])
  @@index([departmentId])
  @@map("role_department_scopes")
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configName  String   @map("config_name")
  configValue String   @map("config_value")
  configGroup String   @default("default") @map("config_group")
  valueType   String   @default("string") @map("value_type")
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  isSensitive Boolean  @default(false) @map("is_sensitive")
  status      Boolean  @default(true)
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([configName])
  @@index([configGroup])
  @@index([configGroup, configKey])
  @@map("system_configs")
}

model Notice {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  title               String
  content             String
  type                String
  status              Boolean   @default(false)
  publishScope        String    @default("TENANT_ALL") @map("publish_scope")
  targetDepartmentIds String?   @map("target_department_ids") @db.Text
  targetRoleCodes     String?   @map("target_role_codes") @db.Text
  isPinned            Boolean   @default(false) @map("is_pinned")
  publisher           String?
  scheduledPublishAt  DateTime? @map("scheduled_publish_at") @db.Timestamp(3)
  publishedAt         DateTime? @map("published_at") @db.Timestamp(3)
  eventKey            String?   @map("event_key")
  eventPayload        String?   @map("event_payload") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([title])
  @@index([type])
  @@index([publishScope])
  @@index([isPinned])
  @@index([scheduledPublishAt])
  @@index([publishedAt])
  @@map("notices")
}

model I18nResource {
  id            String   @id @default(cuid())
  languageCode  String   @map("language_code")
  module        String
  resourceGroup String   @map("resource_group")
  resourceKey   String   @map("resource_key")
  resourceValue String   @map("resource_value") @db.Text
  version       Int      @default(1)
  status        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([languageCode, module, resourceGroup, resourceKey])
  @@index([languageCode, module, status])
  @@index([languageCode, updatedAt])
  @@index([module, resourceKey])
  @@map("i18n_resources")
}

model UserPreference {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  userId         String   @map("user_id")
  layout         String   @default("side")
  theme          String   @default("default")
  darkMode       Boolean  @default(false) @map("dark_mode")
  fullscreen     Boolean  @default(false)
  tabPreferences Json?    @map("tab_preferences")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, userId])
  @@index([tenantId, updatedAt])
  @@map("user_preferences")
}

model WatermarkConfig {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  content   String?
  opacity   Float?
  color     String?
  fontSize  Int?     @map("font_size")
  rotation  Int?
  status    Boolean?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([tenantId, updatedAt])
  @@map("watermark_configs")
}

model CodegenTable {
  id           String          @id @default(cuid())
  tableName    String          @unique @map("table_name")
  tableComment String?         @map("table_comment")
  moduleName   String          @map("module_name")
  businessName String?         @map("business_name")
  className    String?         @map("class_name")
  primaryKey   String?         @map("primary_key")
  columns      CodegenColumn[]
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([moduleName])
  @@map("codegen_tables")
}

model CodegenColumn {
  id            String      @id @default(cuid())
  tableId       String      @map("table_id")
  columnName    String      @map("column_name")
  propertyName  String      @map("property_name")
  columnComment String?     @map("column_comment")
  tsType        String      @default("string") @map("ts_type")
  formType      String      @default("input") @map("form_type")
  queryType     String      @default("none") @map("query_type")
  listVisible   Boolean     @default(true) @map("list_visible")
  sort          Int         @default(0)
  table         CodegenTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tableId, columnName])
  @@index([tableId, sort])
  @@map("codegen_columns")
}
