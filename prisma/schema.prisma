generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  nickname  String?
  roles     UserRole[]
  createdAt DateTime   @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt DateTime   @updatedAt @db.Timestamp(3) @map("updated_at")

  @@map("users")
}

model Menu {
  id        Int        @id
  parentId  Int?       @map("parent_id")
  title     String
  name      String
  type      Int
  path      String
  menuKey   String   @map("menu_key")
  icon      String?
  layout    String?
  isVisible Boolean    @default(true) @map("is_visible")
  component String
  redirect  String?
  meta      Json?
  sort      Int        @default(0)
  roles     RoleMenu[]
  createdAt DateTime   @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt DateTime   @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([parentId])
  @@index([sort])
  @@map("menus")
}

model Dictionary {
  id         String   @id
  parentId   String?  @map("parent_id")
  weight     Int
  name       String
  tenantId   String?  @map("tenant_id")
  dictLabel  String   @map("dict_label")
  dictValue  String   @map("dict_value")
  category   String
  sortCode   Int      @map("sort_code")
  deleteFlag String   @map("delete_flag")
  createTime String?  @map("create_time")
  createUser String?  @map("create_user")
  updateTime String?  @map("update_time")
  updateUser String?  @map("update_user")
  createdAt  DateTime @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt  DateTime @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([parentId])
  @@index([dictValue])
  @@index([sortCode])
  @@map("dictionaries")
}

model Role {
  id                   String                @id @default(cuid())
  name                 String
  code                 String              @unique
  sort                 Int                   @default(0)
  status               Boolean               @default(true)
  dataScope            String                @default("ALL") @map("data_scope")
  remark               String?
  users                UserRole[]
  menus                RoleMenu[]
  dataScopeDepartments RoleDepartmentScope[]
  createdAt            DateTime              @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt            DateTime              @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([name])
  @@index([sort])
  @@map("roles")
}

model Department {
  id              Int                  @id
  parentId        Int?                 @map("parent_id")
  name            String
  code            String               @unique
  leader          String?
  phone           String?
  email           String?
  sort            Int                  @default(0)
  status          Boolean              @default(true)
  remark          String?
  dataScopeRoles  RoleDepartmentScope[]
  createdAt       DateTime             @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt       DateTime             @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([parentId])
  @@index([name])
  @@index([sort])
  @@map("departments")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @db.Timestamp(3) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RoleMenu {
  roleId     String   @map("role_id")
  menuId     Int      @map("menu_id")
  assignedAt DateTime @default(now()) @db.Timestamp(3) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@index([menuId])
  @@map("role_menus")
}

model RoleDepartmentScope {
  roleId       String     @map("role_id")
  departmentId Int        @map("department_id")
  assignedAt   DateTime   @default(now()) @db.Timestamp(3) @map("assigned_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([roleId, departmentId])
  @@index([departmentId])
  @@map("role_department_scopes")
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configName  String   @map("config_name")
  configValue String   @map("config_value")
  valueType   String   @default("string") @map("value_type")
  remark      String?
  createdAt   DateTime @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([configName])
  @@map("system_configs")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String
  status      Boolean  @default(false)
  publisher   String?
  publishedAt DateTime? @db.Timestamp(3) @map("published_at")
  createdAt   DateTime @default(now()) @db.Timestamp(3) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamp(3) @map("updated_at")

  @@index([title])
  @@index([type])
  @@index([publishedAt])
  @@map("notices")
}
