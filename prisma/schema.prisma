generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TenantPackage {
  id           String   @id
  name         String
  code         String   @unique
  status       Boolean  @default(true)
  maxUsers     Int?     @map("max_users")
  maxRoles     Int?     @map("max_roles")
  maxMenus     Int?     @map("max_menus")
  featureFlags Json?    @map("feature_flags")
  remark       String?
  tenants      Tenant[]
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([status])
  @@map("tenant_packages")
}

model Tenant {
  id            String           @id
  code          String           @unique
  name          String
  status        String           @default("ACTIVE")
  expiresAt     DateTime?        @map("expires_at") @db.DateTime(3)
  contactName   String?          @map("contact_name")
  contactPhone  String?          @map("contact_phone")
  contactEmail  String?          @map("contact_email")
  packageId     String?          @map("package_id")
  tenantPackage TenantPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  remark        String?
  auditLogs     TenantAuditLog[]
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([status])
  @@index([packageId])
  @@map("tenants")
}

model TenantAuditLog {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  action           String
  operatorTenantId String?  @map("operator_tenant_id")
  operatorUserId   String?  @map("operator_user_id")
  detail           Json?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([operatorTenantId])
  @@index([operatorUserId])
  @@map("tenant_audit_logs")
}

model DashboardVisit {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  visitorId  String   @map("visitor_id")
  sessionId  String   @map("session_id")
  routePath  String   @map("route_path")
  routeTitle String   @map("route_title")
  routeIcon  String?  @map("route_icon")
  visitedAt  DateTime @default(now()) @map("visited_at") @db.Timestamp(3)

  @@index([tenantId, visitedAt])
  @@index([tenantId, userId, visitedAt])
  @@index([tenantId, sessionId, visitedAt])
  @@index([tenantId, visitorId, visitedAt])
  @@index([tenantId, routePath, visitedAt])
  @@map("dashboard_visits")
}

model SystemLog {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  operatorUserId String   @map("operator_user_id")
  operatorName   String   @map("operator_name")
  module         String
  content        String   @db.Text
  ipAddress      String   @map("ip_address")
  region         String
  browserVersion String   @map("browser_version")
  terminalSystem String   @map("terminal_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([tenantId, createdAt])
  @@index([tenantId, module, createdAt])
  @@index([tenantId, operatorUserId, createdAt])
  @@index([tenantId, operatorName, createdAt])
  @@map("system_logs")
}

model User {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  departmentId Int?        @map("department_id")
  username     String
  password     String
  nickname     String?
  phone        String?
  email        String?
  avatar       String?
  status       Boolean     @default(true)
  lastLoginAt  DateTime?   @map("last_login_at") @db.Timestamp(3)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  roles        UserRole[]
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, username])
  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("users")
}

model Menu {
  id        Int        @id @default(autoincrement())
  parentId  Int?       @map("parent_id")
  title     String
  name      String
  type      Int
  path      String
  menuKey   String     @map("menu_key")
  icon      String?
  layout    String?
  isVisible Boolean    @default(true) @map("is_visible")
  status    Boolean    @default(true)
  component String
  redirect  String?
  meta      Json?
  sort      Int        @default(0)
  roles     RoleMenu[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([parentId])
  @@index([sort])
  @@map("menus")
}

model Dictionary {
  id         String   @id
  parentId   String?  @map("parent_id")
  weight     Int
  name       String
  tenantId   String?  @map("tenant_id")
  dictLabel  String   @map("dict_label")
  dictValue  String   @map("dict_value")
  category   String
  sortCode   Int      @map("sort_code")
  status     Boolean  @default(true)
  deleteFlag String   @map("delete_flag")
  createTime String?  @map("create_time")
  createUser String?  @map("create_user")
  updateTime String?  @map("update_time")
  updateUser String?  @map("update_user")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([parentId])
  @@index([status])
  @@index([dictValue])
  @@index([sortCode])
  @@map("dictionaries")
}

model Role {
  id                   String                @id @default(cuid())
  tenantId             String                @map("tenant_id")
  name                 String
  code                 String
  sort                 Int                   @default(0)
  status               Boolean               @default(true)
  dataScope            String                @default("ALL") @map("data_scope")
  remark               String?
  users                UserRole[]
  menus                RoleMenu[]
  permissions          RolePermission[]
  dataScopeDepartments RoleDepartmentScope[]
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([name])
  @@index([sort])
  @@map("roles")
}

model Department {
  id             Int                   @id @default(autoincrement())
  tenantId       String                @map("tenant_id")
  parentId       Int?                  @map("parent_id")
  name           String
  code           String
  leader         String?
  phone          String?
  email          String?
  sort           Int                   @default(0)
  status         Boolean               @default(true)
  remark         String?
  users          User[]
  dataScopeRoles RoleDepartmentScope[]
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamp(3)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([name])
  @@index([sort])
  @@map("departments")
}

model UserRole {
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([tenantId])
  @@index([roleId])
  @@map("user_roles")
}

model RoleMenu {
  tenantId   String   @map("tenant_id")
  roleId     String   @map("role_id")
  menuId     Int      @map("menu_id")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@index([tenantId])
  @@index([menuId])
  @@map("role_menus")
}

model RolePermission {
  tenantId       String   @map("tenant_id")
  roleId         String   @map("role_id")
  permissionCode String   @map("permission_code")
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamp(3)
  role           Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionCode])
  @@index([tenantId])
  @@index([permissionCode])
  @@map("role_permissions")
}

model RoleDepartmentScope {
  tenantId     String     @map("tenant_id")
  roleId       String     @map("role_id")
  departmentId Int        @map("department_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamp(3)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([roleId, departmentId])
  @@index([tenantId])
  @@index([departmentId])
  @@map("role_department_scopes")
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configName  String   @map("config_name")
  configValue String   @map("config_value")
  valueType   String   @default("string") @map("value_type")
  status      Boolean  @default(true)
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([configName])
  @@map("system_configs")
}

model Notice {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  title       String
  content     String
  type        String
  status      Boolean   @default(false)
  publisher   String?
  publishedAt DateTime? @map("published_at") @db.Timestamp(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([tenantId])
  @@index([title])
  @@index([type])
  @@index([publishedAt])
  @@map("notices")
}
